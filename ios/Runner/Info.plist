<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Offline Connect</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>offline_connect</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

        <!-- BLE Permissions -->
        <key>NSBluetoothAlwaysUsageDescription</key>
        <string>Offline Connect uses Bluetooth to anonymously discover nearby peers and establish offline messaging connections without tracking your geographic location.</string>
        <key>NSBluetoothPeripheralUsageDescription</key>
        <string>Offline Connect uses Bluetooth to anonymously advertise your presence to nearby peers so you can chat entirely offline.</string>

        <!-- Wi-Fi Direct / Local Network for Broadband Bridge -->
        <key>NSLocalNetworkUsageDescription</key>
        <string>Offline Connect requires access to your local network to establish high-speed offline peer-to-peer messaging (Wi-Fi Direct) with users you choose to interact with.</string>
        <key>NSBonjourServices</key>
        <array>
                <string>_googlecast._tcp</string>
                <string>_nearby._tcp</string>
        </array>

        <!-- Profile Photo Permissions -->
        <key>NSCameraUsageDescription</key>
        <string>Offline Connect requires camera access so you can take a profile picture to represent your physical offline identity.</string>
        <key>NSPhotoLibraryUsageDescription</key>
        <string>Offline Connect requires access to your photo library so you can select a profile picture to represent your physical offline identity.</string>

        <!-- Background BLE Modes -->
        <key>UIBackgroundModes</key>
        <array>
                <string>bluetooth-central</string>
                <string>bluetooth-peripheral</string>
        </array>
</dict>
</plist>
